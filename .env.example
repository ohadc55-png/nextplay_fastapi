# NEXTPLAY (FastAPI) — environment variables
# Copy to .env and fill in. All keys are read by src/core/config.py.

# === Environment / runtime ===
RAILWAY_ENVIRONMENT=                  # "production" / "staging" on Railway; empty locally
LOG_LEVEL=INFO
PORT=5050
BASE_URL=http://localhost:5050
APP_BASE_URL=http://localhost:5050    # used by email + auth links
STATIC_URL=                           # external CDN; empty -> serve from /static
CORS_ORIGINS=                         # comma-separated; auto-derived in prod when empty

# === Database ===
DATABASE_URL=                         # postgresql://...; empty -> aiosqlite local
DB_POOL_MAX=10

# === OpenAI / AI ===
OPENAI_API_KEY=
SERPER_API_KEY=
JINA_API_KEY=
ENABLE_RESEARCH_AGENT=true            # "true" / "false" / "0" / "1"
ENABLE_PLAYWRIGHT_FALLBACK=1          # 0 in Railway (no Chromium); 1 locally

# === Auth ===
JWT_SECRET_KEY=                       # generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET_KEY=                   # also accepts FLASK_SECRET_KEY for back-compat
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# === OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# === Admin ===
ADMIN_EMAILS=admin@nextplay.co        # comma-separated allowlist for /admin/*
ADMIN_EMAIL=ohadc55@gmail.com         # single recipient for admin email tooling
ADMIN_PASSWORD_HASH=                  # bcrypt; gen with: python -c "import bcrypt; print(bcrypt.hashpw(b'PASSWORD', bcrypt.gensalt(12)).decode())"

# === AWS S3 ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=nextplay-videos
AWS_S3_REGION=eu-central-1
CLOUDFRONT_DOMAIN=

# === Email (Resend) ===
EMAIL_MODE=console                    # "console" prints to stdout; "resend" sends via API
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME_MK=Ohad from NextPlay
EMAIL_FROM_NAME_TX=NextPlay Team

# === Web Push (VAPID) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ohadc55@gmail.com
PUSH_MORNING_START=10
PUSH_MORNING_END=12                   # exclusive
PUSH_INACTIVE_HOURS=48

# === Internal cron auth ===
CRON_SECRET=                          # required header value for /api/internal/run-push-jobs

# === Monitoring ===
SENTRY_DSN=
