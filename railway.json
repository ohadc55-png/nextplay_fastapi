{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt && python scripts/build.py"
  },
  "deploy": {
    "startCommand": "alembic upgrade head && uvicorn src.main:app --host 0.0.0.0 --port $PORT --workers 2 --timeout-keep-alive 300 --access-log",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30
  }
}
